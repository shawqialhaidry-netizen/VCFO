# VCFO Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=vcfo-change-this-secret-in-production

# ── Database (PostgreSQL only — SQLite is not supported) ────────────────────
DATABASE_URL=postgresql://vcfo:vcfo@127.0.0.1:5432/vcfo

# Optional: pytest / scripts — use a disposable DB to avoid wiping dev data.
# Quick local test DB (Docker): docker compose -f docker-compose.test.yml up -d
# TEST_DATABASE_URL=postgresql+psycopg2://vcfo:vcfo@127.0.0.1:5433/vcfo_test
#
# Alternatively create repo-root `.env.test` with only TEST_DATABASE_URL=...
# (loaded by tests/conftest.py before the test engine is created).

# ── Access control ────────────────────────────────────────────────────────────
# false = dev-friendly (no auth required for read endpoints)
# true  = production (all endpoints require valid Bearer token)
ENFORCE_MEMBERSHIP=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend URL for production:
# CORS_ORIGINS=["https://app.yourdomain.com","http://localhost:5173"]

# ── Production guard ──────────────────────────────────────────────────────────
# Set to true to block startup if JWT_SECRET_KEY is default or DB unreachable
PRODUCTION_MODE=false

# ── Optional ──────────────────────────────────────────────────────────────────
DEBUG=false
