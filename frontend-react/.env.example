# VCFO Frontend Environment Variables
# Copy to .env.local and fill in for your deployment

# Backend API base URL (default: same origin via proxy)
# For production, set this to your backend server URL
VITE_API_BASE_URL=

# App version (shown in footer/status)
VITE_APP_VERSION=1.0.0

# Enable demo mode (shows landing screen for unauthenticated users)
VITE_DEMO_MODE=true
